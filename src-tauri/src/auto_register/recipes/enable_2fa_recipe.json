{
  "version": 1,
  "name": "Enable ChatGPT 2FA",
  "description": "Recorded flow: Navigate to Settings > Privacy > Enable two-factor authentication",
  "defaults": {
    "timeout_ms": 10000,
    "auto_wait": true
  },
  "steps": [
    {
      "id": "navigate_settings",
      "tool": "navigate",
      "arguments": {
        "url": "https://chatgpt.com/settings/privacy"
      }
    },
    {
      "id": "click_enable_2fa",
      "tool": "click_element",
      "arguments": {
        "locator": {
          "by": "text",
          "value": "Enable two-factor authentication"
        }
      }
    }
  ]
}
